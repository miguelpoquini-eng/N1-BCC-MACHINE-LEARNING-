      "source": [
        "# Contando o total de interações possíveis (Usuários x Produtos)\n",
        "total_elementos = matriz_completa.shape[0] * matriz_completa.shape[1]\n",
        "\n",
        "# Contando quantos elementos são zero (não houve interação/compra)\n",
        "total_zeros = (matriz_completa == 0).sum().sum()\n",
        "\n",
        "# Cálculo percentual\n",
        "percentual_esparsidade = (total_zeros / total_elementos) * 100\n",
        "percentual_densidade = 100 - percentual_esparsidade\n",
        "\n",
        "print(\"======================================================\")\n",
        "print(\"🔍 DIAGNÓSTICO MATRICIAL INFRAESTRUTURAL\")\n",
